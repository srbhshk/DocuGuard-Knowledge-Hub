{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": ["src", "vite.config.ts", "jest.config.cjs"]
}
